generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum SystemRole {
  USER
  SUPER_ADMIN
}

enum ResourceType {
  PROJECT
  AUDIT_AREA
  PROCESS
  CONTROL
  TEST_STEP
  EVIDENCE
  FINDING
  FILE
  NOTE
  MEMBER
  ROLE
  REPORT
}

enum PermissionAction {
  READ
  CREATE
  UPDATE
  DELETE
  MANAGE
  ASSIGN
}

model User {
  id           String   @id //@default(cuid())
  email        String   @unique
  name         String?
  passwordHash String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  systemRole      SystemRole @default(USER)

  refreshTokens RefreshToken[] // ✅ opposite relation field

  projectMembers ProjectMember[]

  auditLogs AuditLog[]

  isTwoFactorEnabled Boolean @default(false)
  twoFactorSecret    String? // encrypted later if you want
}

model RefreshToken {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model Project {
  id          String   @id //@default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members   ProjectMember[]
  auditLogs AuditLog[]

  projectRoles ProjectRole[]

  auditAreas AuditArea[]
}

// Nusako naudotojo vaidmenį projekte (pvz., savininkas, redaktorius, žiūrovas) pagal roles ir permissionus
model ProjectMember {
  id        String   @id //@default(cuid())
  projectId String
  userId    String
  isOwner   Boolean  @default(false)
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  roles       ProjectMemberRole[]
  permissions ProjectMemberPermission[]

  @@unique([projectId, userId])
  @@index([userId])
  @@index([projectId])
}

// Projekte sukuta rolė ir jai priskirti leidimai bei vartotojai
model ProjectRole {
  id          String   @id //@default(cuid())
  projectId   String
  name        String
  description String?
  isSystem    Boolean  @default(false) // optional if you want default built-in project roles
  createdAt   DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  permissions ProjectRolePermission[]
  members     ProjectMemberRole[]

  @@unique([projectId, name])
}

//Rolei nustatytų leidimų sąrašas, pvz.: skaityti procesas1 ir redaguoti procesas2 ar pan.
model ProjectRolePermission {
  id         String           @id //@default(cuid())
  roleId     String
  resource   ResourceType
  action     PermissionAction
  scopeId    String? // optional, later for specific component/node/etc.

  role ProjectRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, resource, action, scopeId])
  @@index([roleId, resource, action])
  @@index([roleId, scopeId])
}

// Nurodo, kurie vartotojai turi kokias roles projekte
model ProjectMemberRole {
  id              String   @id //@default(cuid())
  projectMemberId String
  roleId          String

  projectMember ProjectMember @relation(fields: [projectMemberId], references: [id], onDelete: Cascade)
  role          ProjectRole   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([projectMemberId, roleId])
}

// Tiesioginiai leidimai, nepriklausantys rolei, pvz., jei nori suteikti kam nors tik vieną leidimą be rolei priskyrimo
model ProjectMemberPermission {
  id              String           @id //@default(cuid())
  projectMemberId String
  resource        ResourceType
  action          PermissionAction
  scopeId         String?

  projectMember ProjectMember @relation(fields: [projectMemberId], references: [id], onDelete: Cascade)

  @@unique([projectMemberId, resource, action, scopeId])
  @@index([projectMemberId, resource, action])
  @@index([projectMemberId, scopeId])
}

model AuditLog {
  id        String      @id //@default(cuid())
  projectId String
  actorId   String? // null for system actions later
  action    AuditAction
  entity    String? // "Project", "ProjectMember", "Node", ...
  entityId  String?
  details   Json?
  createdAt DateTime    @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  actor   User?   @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([actorId])
  @@index([createdAt])
}

enum AuditAction {
  PROJECT_CREATED
  PROJECT_UPDATED
  PROJECT_DELETED

  MEMBER_ADDED
  MEMBER_ROLE_UPDATED
  MEMBER_REMOVED
  OWNER_TRANSFERRED

  ROLE_CREATED
  ROLE_UPDATED
  ROLE_DELETED

  DIRECT_PERMISSION_GRANTED
  DIRECT_PERMISSION_REVOKED

  AUDIT_AREA_CREATED
  AUDIT_AREA_UPDATED
  AUDIT_AREA_DELETED

  PROCESS_CREATED
  PROCESS_UPDATED
  PROCESS_DELETED

  CONTROL_CREATED
  CONTROL_UPDATED
  CONTROL_DELETED

  TEST_STEP_CREATED
  TEST_STEP_UPDATED
  TEST_STEP_DELETED

  EVIDENCE_CREATED
  EVIDENCE_UPDATED
  EVIDENCE_DELETED

  FINDING_CREATED
  FINDING_UPDATED
  FINDING_DELETED
}

/*Project componets */
model AuditArea {
  id        String   @id
  projectId String
  name      String
  order     Int      @default(0)

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  processes Process[]

  createdAt DateTime @default(now())
}

model Process {
  id          String    @id
  auditAreaId String
  name        String
  order       Int       @default(0)

  auditArea   AuditArea @relation(fields: [auditAreaId], references: [id], onDelete: Cascade)
  controls    Control[]
  evidence    Evidence[]
  findings    Finding[]

  createdAt   DateTime  @default(now())
}

model Control {
  id        String  @id
  processId String
  name      String
  order       Int       @default(0)

  process   Process @relation(fields: [processId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  testSteps TestStep[]
}

model TestStep {
  id        String @id
  controlId String
  description String
  order       Int       @default(0)

  control   Control @relation(fields: [controlId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model Evidence {
  id        String @id
  processId String
  title     String
  type      String
  fileUrl   String?
  order       Int       @default(0)

  process   Process @relation(fields: [processId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model Finding {
  id          String @id
  processId   String
  title       String
  description String
  severity    String
  order       Int       @default(0)

  process     Process @relation(fields: [processId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
}
